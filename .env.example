# ──────────────────────────────────── API credentials ───
# Both providers are supported; set whichever you have billing on.
# Gemini is the default for frame generation (Nano Banana) and video (Veo).
# fal is the alternative for Flux Kontext / Kling / Hailuo.

GEMINI_API_KEY=
FAL_KEY=

# ──────────────────────────────────── Web-UI auth ───
# HTTP Basic Auth on the web surface. Set BOTH to enable; leave either
# blank for unauthenticated local development. Required in production.

AUTH_USERNAME=
AUTH_PASSWORD=

# ──────────────────────────────────── Server ───
# HOST defaults to 0.0.0.0 inside Docker, 127.0.0.1 for local dev unless
# explicitly overridden.
# HOST=127.0.0.1
# PORT=8000
# HOST_PORT=8000  # host-side port when running via docker-compose

# ──────────────────────────────────── Pipeline overrides ───
# Defaults are sensible. Override only if you know what you want.
# JOLTO_FRAME_MODEL=gemini-2.5-flash-image
# JOLTO_VIDEO_MODEL=veo-3.1-fast-generate-preview
# JOLTO_BRIEF_MODEL=gemini-2.5-flash
# JOLTO_COST_CEILING_USD=15.0
